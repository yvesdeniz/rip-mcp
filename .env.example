# ─────────────────────────────────────────────────────────────────────────────
# shd-music MCP server (src/mcp) — run with `bun run src/mcp/index.ts`
# Copy to `.env` and fill in. NEVER commit your real ARL — it is a credential.
# ─────────────────────────────────────────────────────────────────────────────

# Which download backend to use: `deezer` (native, default) or `lucida`.
MUSIC_BACKEND=deezer

# Deezer ARL cookie — required for the native deezer backend.
# Grab it from your browser's Deezer cookies (cookie named "arl").
DEEZER_ARL=

# Preferred quality: FLAC | MP3_320 | MP3_128 (falls back automatically).
MUSIC_QUALITY=FLAC

# Working dir for decrypt/tag before upload (defaults to the OS temp dir).
DOWNLOAD_DIR=/tmp/shd-rips

# Destination music library on THIS server — the "private server" sync target.
MUSIC_LIBRARY_DIR=/srv/music

# How upload_file / rip_track publish: `move` (default) or `copy`.
UPLOAD_MODE=move

# Embed tags + cover art with ffmpeg/metaflac when available (true/false).
EMBED_TAGS=true

# Lucida-flow backend (only used when MUSIC_BACKEND=lucida).
LUCIDA_API_URL=
LUCIDA_API_KEY=

# MCP server log verbosity on stderr: debug | info | warn | error
MCP_LOG_LEVEL=info
